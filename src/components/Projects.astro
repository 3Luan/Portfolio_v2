---
import GitHub from "./icons/GitHub.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"

const PROJECTS = [
  {
    title: "UTC2 Social",
    period: "July 2024 – January 2025",
    description: [
      "Developed client and admin pages for system management.",
      "Built frontend using JavaScript and ReactJS, backend using NodeJS (Express).",
      "Used MongoDB with Mongoose for efficient data storage and management.",
      "Deployed frontend on Vercel and backend on Render."
    ],
    stack:
      "ReactJS, NodeJS, JavaScript, RESTful API, MongoDB, TailwindCSS, Redux, Axios, JWT",
    github: "https://github.com/3Luan/UTC2_Social",
    link: "https://socialutc2.vercel.app",
    image: "/projects/socialUTC2.png",
  },
  {
    title: "Realtime Chat",
    period: "October 2025 – Now",
    description: [
      "Built frontend using TypeScript and VueJS, backend using PHP (Laravel).",
      "Integrated WebSocket for real-time messaging.",
      "Used Amazon SES for transactional emails.",
      "Deployed the entire system on AWS using EC2."
    ],
    stack:
      "PHP, Laravel, TypeScript, VueJS, RESTful API, WebSocket, AWS EC2, Amazon SES",
    github: "https://github.com/3Luan/worksync",
    image: "/projects/worksync.png",
  },
]
---

<section class="flex flex-col gap-24 mt-5">
  {PROJECTS.map(
    ({ image, title, period, description, stack, link, github }) => (
      <article class="group grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        
        <!-- Image -->
        <div class="relative overflow-hidden rounded-2xl shadow-lg">
          <img
            src={image}
            alt={title}
            loading="lazy"
            class="h-64 w-full object-cover transition duration-500 group-hover:scale-105 md:h-full"
          />
        </div>

        <!-- Content -->
        <div class="flex flex-col gap-4">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
            {title}
          </h3>

          <span class="text-sm text-gray-500 dark:text-gray-400">
            {period}
          </span>

          <ul class="list-disc pl-5 space-y-2 text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
            {description.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <p class="text-sm font-medium text-yellow-600 dark:text-yellow-400 mt-2">
            Stack: {stack}
          </p>

          <footer class="flex gap-4 pt-4">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-5" />
                Code
              </LinkButton>
            )}

            {link && (
              <LinkButton href={link}>
                <Link class="size-4" />
                Preview
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    )
  )}
</section>
