---
interface Props {
  title: string
  organization: string
  date: string
  description: string
}

const { title, organization, date, description } = Astro.props
---

<li
  class="relative mx-6 md:mx-12 pb-16 grid
  before:absolute before:left-[-28px] before:top-2
  before:h-full before:border-l before:border-black/20
  dark:before:border-white/15
  md:grid-cols-4 md:gap-8"
>
  <!-- LEFT SIDE -->
  <div class="md:col-span-1 relative">
    <span class="absolute -left-[34px] top-1 text-yellow-500 dark:text-yellow-400 text-2xl">
      &bull;
    </span>

    <div class="sticky top-20 space-y-2">
      <h4 class="text-lg font-semibold text-yellow-600 dark:text-yellow-400">
        {title}
      </h4>

      <h5 class="text-base font-medium text-gray-900 dark:text-white">
        {organization}
      </h5>

      <time class="text-sm text-gray-600 dark:text-gray-400">
        {date}
      </time>
    </div>
  </div>

  <!-- RIGHT SIDE -->
  <div class="md:col-span-3">
    <div class="
      bg-gray-100 border border-black/10
      dark:bg-white/5 dark:border-white/10
      rounded-xl p-5
    ">
    <p class="text-gray-900 dark:text-white leading-relaxed text-sm font-semibold">
        {description}
    </p>
    </div>
  </div>
</li>